{# Shipping Methods Ranked List #}
<div class="bs-chart-container">
	<h3 class="bs-chart-container__title">{{ "Shipping Methods"|t('best-sellers') }}</h3>
	{% if shippingMethods|length > 0 %}
		{% set maxCount = shippingMethods|first.count %}
		<table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
			<thead>
				<tr>
					<th style="text-align: left; padding: 0.5rem; border-bottom: 2px solid #e0e0e0; color: #6c757d; font-size: 0.8rem;">{{ "Method"|t('best-sellers') }}</th>
					<th style="text-align: right; padding: 0.5rem; border-bottom: 2px solid #e0e0e0; color: #6c757d; font-size: 0.8rem;">{{ "Orders"|t('best-sellers') }}</th>
					<th style="text-align: right; padding: 0.5rem; border-bottom: 2px solid #e0e0e0; color: #6c757d; font-size: 0.8rem;">{{ "Shipping Revenue"|t('best-sellers') }}</th>
				</tr>
			</thead>
			<tbody>
				{% for method in shippingMethods %}
					{% set pct = maxCount > 0 ? (method.count / maxCount * 100) : 0 %}
					<tr>
						<td style="padding: 0.5rem; position: relative;">
							<span style="position: absolute; top: 2px; left: 0; bottom: 2px; width: {{ pct }}%; background: rgba(0, 115, 170, 0.08); border-radius: 3px;"></span>
							<span style="position: relative; font-weight: 600;">{{ method.method }}</span>
						</td>
						<td style="padding: 0.5rem; text-align: right;">
							<a href="{{ cpUrl('best-sellers/orders', {shippingMethod: method.method}) }}">{{ method.count|number_format }}</a>
						</td>
						<td style="padding: 0.5rem; text-align: right;">{{ method.revenue|commerceCurrency }}</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	{% else %}
		<p style="color: #999; font-size: 0.9rem;">{{ "No data available"|t('best-sellers') }}</p>
	{% endif %}
</div>
