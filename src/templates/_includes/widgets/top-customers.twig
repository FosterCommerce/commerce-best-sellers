{# Top Customers by Revenue #}
<div class="bs-chart-container">
	<h3 class="bs-chart-container__title">{{ "Top Customers by Revenue"|t('best-sellers') }}</h3>
	{% if topCustomers|length > 0 %}
		{% set maxSpent = topCustomers|first.totalSpent %}
		<table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
			<thead>
				<tr>
					<th style="text-align: left; padding: 0.5rem; border-bottom: 2px solid #e0e0e0; color: #6c757d; font-size: 0.8rem;">{{ "Customer"|t('best-sellers') }}</th>
					<th style="text-align: right; padding: 0.5rem; border-bottom: 2px solid #e0e0e0; color: #6c757d; font-size: 0.8rem;">{{ "Orders"|t('best-sellers') }}</th>
					<th style="text-align: right; padding: 0.5rem; border-bottom: 2px solid #e0e0e0; color: #6c757d; font-size: 0.8rem;">{{ "Revenue"|t('best-sellers') }}</th>
				</tr>
			</thead>
			<tbody>
				{% for customer in topCustomers %}
					{% set pct = maxSpent > 0 ? (customer.totalSpent / maxSpent * 100) : 0 %}
					<tr>
						<td style="padding: 0.5rem; position: relative;">
							<span style="position: absolute; top: 2px; left: 0; bottom: 2px; width: {{ pct }}%; background: rgba(0, 115, 170, 0.08); border-radius: 3px;"></span>
							<span style="position: relative;">{{ customer.email }}</span>
						</td>
						<td style="padding: 0.5rem; text-align: right;">{{ customer.orderCount|number_format }}</td>
						<td style="padding: 0.5rem; text-align: right;">{{ customer.totalSpent|commerceCurrency }}</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	{% else %}
		<p style="color: #999; font-size: 0.9rem;">{{ "No customer data available."|t('best-sellers') }}</p>
	{% endif %}
</div>
