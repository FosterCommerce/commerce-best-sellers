{# Most Used Discounts #}
<div class="bs-chart-container" style="margin-top: 1.5rem;">
	<h3 class="bs-chart-container__title">{{ "Most Used Discounts"|t('best-sellers') }}</h3>
	{% if topDiscounts|length > 0 %}
		{% set maxUses = topDiscounts|first.uses %}
		<table style="width: 100%; font-size: 0.9rem; border-collapse: collapse;">
			<thead>
				<tr>
					<th style="text-align: left; padding: 0.5rem; border-bottom: 2px solid #e0e0e0; color: #6c757d; font-size: 0.8rem;">{{ "Discount"|t('best-sellers') }}</th>
					<th style="text-align: right; padding: 0.5rem; border-bottom: 2px solid #e0e0e0; color: #6c757d; font-size: 0.8rem;">{{ "Orders"|t('best-sellers') }}</th>
					<th style="text-align: right; padding: 0.5rem; border-bottom: 2px solid #e0e0e0; color: #6c757d; font-size: 0.8rem;">{{ "Total Discount"|t('best-sellers') }}</th>
				</tr>
			</thead>
			<tbody>
				{% for discount in topDiscounts %}
					{% set pct = maxUses > 0 ? (discount.uses / maxUses * 100) : 0 %}
					<tr>
						<td style="padding: 0.5rem; position: relative;">
							<span style="position: absolute; top: 2px; left: 0; bottom: 2px; width: {{ pct }}%; background: rgba(0, 115, 170, 0.08); border-radius: 3px;"></span>
							<span style="position: relative; font-weight: 600;">{{ discount.name }}</span>
						</td>
						<td style="padding: 0.5rem; text-align: right;">
							{% if discount.discountId %}
								<a href="{{ cpUrl('best-sellers/orders', {discountId: discount.discountId}) }}">{{ discount.uses|number_format }}</a>
							{% else %}
								{{ discount.uses|number_format }}
							{% endif %}
						</td>
						<td style="padding: 0.5rem; text-align: right;">{{ discount.totalDiscount|commerceCurrency }}</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	{% else %}
		<p style="color: #999; font-size: 0.9rem;">{{ "No discounts used in this period."|t('best-sellers') }}</p>
	{% endif %}
</div>
