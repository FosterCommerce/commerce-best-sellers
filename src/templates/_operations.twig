{% extends 'best-sellers/_layouts/reports' %}

{% set title = "Operations"|t('best-sellers') %}
{% set selectedSubnavItem = 'operations' %}

{% block reportContent %}
	<div class="bs-columns">
		{% include 'best-sellers/_includes/widgets/items-per-order' %}
		{% include 'best-sellers/_includes/widgets/shipping-methods' %}
	</div>

	{% include 'best-sellers/_includes/widgets/discount-trend' %}
	{% include 'best-sellers/_includes/widgets/coupon-usage' %}
{% endblock %}

{% js %}
document.addEventListener('DOMContentLoaded', function () {
	var colors = ['#0073aa', '#a100ff', '#27ae60', '#f39c12', '#e74c3c', '#3498db', '#9b59b6', '#1abc9c', '#e67e22', '#2ecc71'];

	{% if itemsPerOrder.counts|length > 0 %}
	new Chart(document.getElementById('itemsPerOrderChart').getContext('2d'), {
		type: 'bar',
		data: {
			labels: {{ itemsPerOrder.labels|json_encode|raw }},
			datasets: [{
				label: '{{ "Orders"|t("best-sellers") }}',
				data: {{ itemsPerOrder.counts|json_encode|raw }},
				backgroundColor: 'rgba(0, 115, 170, 0.6)',
				borderColor: '#0073aa',
				borderWidth: 1
			}]
		},
		options: {
			responsive: true,
			maintainAspectRatio: false,
			plugins: { legend: { display: false } },
			scales: {
				x: { title: { display: true, text: '{{ "Items"|t("best-sellers") }}' } },
				y: { beginAtZero: true, title: { display: true, text: '{{ "Orders"|t("best-sellers") }}' } }
			}
		}
	});
	{% endif %}

	{% if shippingMethods|length > 0 %}
	var shipLabels = {{ shippingMethods|column('method')|json_encode|raw }};
	var shipData = {{ shippingMethods|column('count')|json_encode|raw }};

	new Chart(document.getElementById('shippingChart').getContext('2d'), {
		type: 'doughnut',
		data: {
			labels: shipLabels,
			datasets: [{
				data: shipData,
				backgroundColor: colors.slice(0, shipLabels.length)
			}]
		},
		options: {
			responsive: true,
			maintainAspectRatio: false,
			plugins: { legend: { position: 'bottom' } }
		}
	});
	{% endif %}

	{% if discountTrend.labels|length > 0 %}
	var dtLabels = {{ discountTrend.labels|json_encode|raw }};
	var dtData = {{ discountTrend.discounts|json_encode|raw }};
	var timeScale = BestSellersReports.getTimeScale(dtLabels);

	new Chart(document.getElementById('discountTrendChart').getContext('2d'), {
		type: 'line',
		data: {
			labels: dtLabels,
			datasets: [{
				label: '{{ "Discount"|t("best-sellers") }}',
				data: dtData,
				borderColor: '#e74c3c',
				backgroundColor: 'transparent',
				fill: false,
				cubicInterpolationMode: 'monotone',
				pointRadius: dtLabels.length === 1 ? 6 : 1,
				borderWidth: 1.5
			}]
		},
		options: {
			responsive: true,
			maintainAspectRatio: false,
			plugins: { legend: { position: 'bottom' } },
			scales: {
				x: {
					type: 'time',
					time: {
						unit: timeScale.unit,
						stepSize: timeScale.stepSize,
						displayFormats: { day: 'MMM d', month: 'MMM yyyy' }
					}
				},
				y: { beginAtZero: true }
			}
		}
	});
	{% endif %}
});
{% endjs %}
