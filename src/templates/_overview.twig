{% extends 'best-sellers/_layouts/reports' %}
{% import 'best-sellers/_includes/kpi-card' as kpi %}
{% import 'best-sellers/_includes/summary' as summaryBlock %}

{% set title = "Dashboard"|t('best-sellers') %}
{% set selectedSubnavItem = 'overview' %}

{% block reportContent %}
	{# 1. Hero row #}
	<div class="bs-section bs-section--hero">
		{{ summaryBlock.render(summaries.orders) }}
		<div class="bs-kpi-grid bs-kpi-grid--4">
			{% for card in healthCheckCards %}
				{{ kpi.card(card) }}
			{% endfor %}
		</div>
		{% include 'best-sellers/_includes/widgets/overview-chart' %}
	</div>

	{# 2. Discounts & Order Composition #}
	<div class="bs-section">
		<div style="display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1rem;">
			<h3 class="bs-section__title" style="margin: 0;">{{ "Discounts & Order Composition"|t('best-sellers') }}</h3>
			<a href="{{ cpUrl('best-sellers/orders') }}" class="go" style="font-size: 0.85rem;">{{ "See all orders"|t('best-sellers') }}</a>
		</div>
		{{ summaryBlock.render(summaries.discounts) }}
		<div class="bs-kpi-grid bs-kpi-grid--3">
			{% for card in discountCards %}
				{{ kpi.card(card) }}
			{% endfor %}
		</div>
		<div class="bs-columns">
			{% include 'best-sellers/_includes/widgets/discounted-vs-fullprice' %}
			{% include 'best-sellers/_includes/widgets/top-discounts' %}
		</div>
		<div class="bs-columns">
			{% include 'best-sellers/_includes/widgets/items-per-order' %}
			{% include 'best-sellers/_includes/widgets/shipping-methods' %}
		</div>
	</div>

	{# 3. Customers & Retention #}
	<div class="bs-section">
		<div style="display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1rem;">
			<h3 class="bs-section__title" style="margin: 0;">{{ "Customers & Retention"|t('best-sellers') }}</h3>
			<a href="{{ cpUrl('best-sellers/customers') }}" class="go" style="font-size: 0.85rem;">{{ "See all customers"|t('best-sellers') }}</a>
		</div>
		{{ summaryBlock.render(summaries.customers) }}
		<div class="bs-kpi-grid bs-kpi-grid--3">
			{% for card in customerCards %}
				{{ kpi.card(card) }}
			{% endfor %}
		</div>
		<div class="bs-columns">
			{% include 'best-sellers/_includes/widgets/top-customers' %}
			{% include 'best-sellers/_includes/widgets/ltv-table' %}
		</div>
		{% include 'best-sellers/_includes/widgets/new-vs-returning-chart' %}
	</div>

	{# 4. Cart Abandonment #}
	<div class="bs-section">
		{{ summaryBlock.render(summaries.abandonment) }}
		{% include 'best-sellers/_includes/widgets/cart-abandonment' %}
	</div>

	{# 5. Product Performance #}
	<div class="bs-section">
		<div style="display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1rem;">
			<h3 class="bs-section__title" style="margin: 0;">{{ "Product Performance"|t('best-sellers') }}</h3>
			<a href="{{ cpUrl('best-sellers/products') }}" class="go" style="font-size: 0.85rem;">{{ "See all products"|t('best-sellers') }}</a>
		</div>
		{{ summaryBlock.render(summaries.products) }}
		<div class="bs-kpi-grid bs-kpi-grid--{{ productCards|length }}">
			{% for card in productCards %}
				{{ kpi.card(card) }}
			{% endfor %}
		</div>
		{% if bestSellers|length > 0 %}
			{% include 'best-sellers/_includes/widgets/best-sellers-table' %}
		{% endif %}
	</div>
{% endblock %}

{% js %}
document.addEventListener('DOMContentLoaded', function () {
	var labels = {{ dailyLabels|json_encode|raw }};
	var ordersData = {{ dailyOrders|json_encode|raw }};
	var revenueData = {{ dailyRevenue|json_encode|raw }};

	// Sparklines
	var sparklineMap = {{ sparklines|json_encode|raw }};
	Object.keys(sparklineMap).forEach(function (id) {
		BestSellersReports.createSparkline(id, sparklineMap[id]);
	});

	// New vs Returning chart
	{% if newVsReturning.labels|length > 0 %}
	var nvrLabels = {{ newVsReturning.labels|json_encode|raw }};
	var nvrTimeScale = BestSellersReports.getTimeScale(nvrLabels);

	new Chart(document.getElementById('newVsReturningChart').getContext('2d'), {
		type: 'line',
		data: {
			labels: nvrLabels,
			datasets: [
				{
					label: '{{ "New"|t("best-sellers") }}',
					data: {{ newVsReturning.new|json_encode|raw }},
					borderColor: '#27ae60',
					backgroundColor: 'rgba(39, 174, 96, 0.1)',
					fill: true,
					cubicInterpolationMode: 'monotone',
					pointRadius: nvrLabels.length === 1 ? 6 : 1,
					borderWidth: 1.5
				},
				{
					label: '{{ "Returning"|t("best-sellers") }}',
					data: {{ newVsReturning.returning|json_encode|raw }},
					borderColor: '#0073aa',
					backgroundColor: 'rgba(0, 115, 170, 0.1)',
					fill: true,
					cubicInterpolationMode: 'monotone',
					pointRadius: nvrLabels.length === 1 ? 6 : 1,
					borderWidth: 1.5
				}
			]
		},
		options: {
			responsive: true,
			maintainAspectRatio: false,
			interaction: { mode: 'index', intersect: false },
			plugins: {
					legend: { position: 'bottom' },
					tooltip: {
						callbacks: {
							title: function (items) {
								var date = new Date(items[0].parsed.x);
								return date.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
							}
						}
					}
				},
			scales: {
				x: {
					type: 'time',
					time: { unit: nvrTimeScale.unit, stepSize: nvrTimeScale.stepSize, displayFormats: { day: 'MMM d', month: 'MMM yyyy' }, tooltipFormat: 'MMM d, yyyy' }
				},
				y: { beginAtZero: true }
			}
		}
	});
	{% endif %}


	// Toggle chart
	var datasets = {
		revenue: {
			current: revenueData,
			prev: {{ prevDailyRevenue|json_encode|raw }},
			label: '{{ "Revenue"|t("best-sellers") }}',
			prevLabel: '{{ "Previous Period"|t("best-sellers") }}'
		},
		orders: {
			current: ordersData,
			prev: {{ prevDailyOrders|json_encode|raw }},
			label: '{{ "Orders"|t("best-sellers") }}',
			prevLabel: '{{ "Previous Period"|t("best-sellers") }}'
		},
		aov: {
			current: {{ dailyAov|json_encode|raw }},
			prev: {{ prevDailyAov|json_encode|raw }},
			label: '{{ "AOV"|t("best-sellers") }}',
			prevLabel: '{{ "Previous Period"|t("best-sellers") }}'
		}
	};

	if (labels.length > 0) {
		var timeScale = BestSellersReports.getTimeScale(labels);
		var ctx = document.getElementById('overviewChart').getContext('2d');

		var overviewChart = new Chart(ctx, {
			type: 'line',
			data: {
				labels: labels,
				datasets: [
					{
						label: datasets.revenue.label,
						data: datasets.revenue.current,
						borderColor: '#0073aa',
						backgroundColor: 'transparent',
						fill: false,
						cubicInterpolationMode: 'monotone',
						pointRadius: labels.length === 1 ? 6 : 1,
						borderWidth: 1.5
					},
					{
						label: datasets.revenue.prevLabel,
						data: datasets.revenue.prev,
						borderColor: '#ccc',
						backgroundColor: 'transparent',
						borderDash: [5, 5],
						cubicInterpolationMode: 'monotone',
						pointRadius: 0,
						borderWidth: 1.5
					}
				]
			},
			options: {
				responsive: true,
				maintainAspectRatio: false,
				interaction: { mode: 'index', intersect: false },
				plugins: { legend: { position: 'bottom' } },
				scales: {
					x: {
						type: 'time',
						time: {
							unit: timeScale.unit,
							stepSize: timeScale.stepSize,
							displayFormats: { day: 'MMM d', month: 'MMM yyyy' }
						}
					},
					y: { beginAtZero: true }
				}
			}
		});

		document.querySelectorAll('.bs-chart-toggle__btn').forEach(function (btn) {
			btn.addEventListener('click', function () {
				document.querySelectorAll('.bs-chart-toggle__btn').forEach(function (b) {
					b.classList.remove('bs-chart-toggle__btn--active');
				});
				this.classList.add('bs-chart-toggle__btn--active');

				var key = this.getAttribute('data-chart');
				var ds = datasets[key];
				overviewChart.data.datasets[0].data = ds.current;
				overviewChart.data.datasets[0].label = ds.label;
				overviewChart.data.datasets[1].data = ds.prev;
				overviewChart.data.datasets[1].label = ds.prevLabel;
				overviewChart.update();
			});
		});
	}
	// Cart abandonment widget
	var abandonmentData = {{ cartAbandonment|json_encode|raw }};
	var abandonmentContainer = document.getElementById('cart-abandonment-content');
	var anonymousToggle = document.getElementById('include-anonymous-carts');
	var currentAbandonmentTab = 'overview';

	function formatAbandonmentNumber(number) {
		return Number(number).toLocaleString();
	}

	function formatAbandonmentCurrency(number) {
		return BestSellersReports.formatCurrency(number);
	}

	function renderAbandonment() {
		if (!abandonmentContainer || !abandonmentData) return;

		var includeAnonymous = anonymousToggle && anonymousToggle.checked;
		var data = abandonmentData;

		// Calculate filtered totals
		var totalAbandoned = includeAnonymous ? data.totalAbandoned : data.withCustomer;
		var abandonedValue = includeAnonymous ? data.abandonedValue : data.abandonedValueWithEmail;
		var totalCarts = totalAbandoned + data.totalCompleted;
		var rate = totalCarts > 0 ? Math.round((totalAbandoned / totalCarts) * 1000) / 10 : 0;

		var html = '';

		var tabDescriptions = {
			'overview': 'All carts with line items that haven\'t been updated for at least 4 hours. These numbers may differ from external analytics services which track intent differently.',
			'4-24h': 'Carts abandoned between 4 and 24 hours ago.',
			'1-7d': 'Carts abandoned between 1 and 7 days ago.',
			'7d+': 'Carts abandoned more than 7 days ago.'
		};

		html += '<p style="font-size:0.85rem;color:#6c757d;margin:0 0 1rem;">' + tabDescriptions[currentAbandonmentTab] + '</p>';

		if (currentAbandonmentTab === 'overview') {
			html += '<div class="bs-kpi-grid" style="grid-template-columns: 1fr 1fr;">';
			html += '<div class="bs-kpi-card"><div class="bs-kpi-card__header"><p class="bs-kpi-card__label">Abandonment Rate</p></div>';
			html += '<p class="bs-kpi-card__value">' + rate + '%</p>';
			html += '<p style="margin:0.5rem 0 0;font-size:0.8rem;color:#999;">' + formatAbandonmentNumber(totalAbandoned) + ' out of ' + formatAbandonmentNumber(totalCarts) + ' carts</p></div>';

			html += '<div class="bs-kpi-card"><div class="bs-kpi-card__header"><p class="bs-kpi-card__label">Abandoned Value</p></div>';
			html += '<p class="bs-kpi-card__value">' + formatAbandonmentCurrency(abandonedValue) + '</p></div>';
			html += '</div>';

			// Age breakdown
			if (totalAbandoned > 0) {
				html += '<div style="margin-top:1.5rem;">';
				html += '<p class="bs-kpi-card__label" style="margin-bottom:0.5rem;">By age</p>';
				html += '<div style="display:flex;height:24px;border-radius:4px;overflow:hidden;">';
				var barColors = {'4-24h': 'rgba(0,115,170,0.4)', '1-7d': 'rgba(0,115,170,0.6)', '7d+': 'rgba(0,115,170,0.8)'};
				var ageLabels = ['4-24h', '1-7d', '7d+'];
				for (var ageIndex = 0; ageIndex < ageLabels.length; ageIndex++) {
					var ageLabel = ageLabels[ageIndex];
					var ageData = data.byAge[ageLabel];
					var ageCount = includeAnonymous ? ageData.count : ageData.withCustomer;
					var agePercent = totalAbandoned > 0 ? (ageCount / totalAbandoned * 100) : 0;
					if (agePercent > 0) {
						html += '<div style="width:' + agePercent + '%;background:' + barColors[ageLabel] + ';display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.7rem;font-weight:600;" title="' + ageLabel + ': ' + ageCount + ' carts">';
						if (agePercent > 8) html += ageLabel;
						html += '</div>';
					}
				}
				html += '</div>';
				html += '<div style="display:flex;margin-top:0.4rem;font-size:0.8rem;color:#999;">';
				for (var ageIndex2 = 0; ageIndex2 < ageLabels.length; ageIndex2++) {
					var ageLabel2 = ageLabels[ageIndex2];
					var ageData2 = data.byAge[ageLabel2];
					var ageCount2 = includeAnonymous ? ageData2.count : ageData2.withCustomer;
					var labelPercent = totalAbandoned > 0 ? (ageCount2 / totalAbandoned * 100) : 0;
					html += '<span style="width:' + labelPercent + '%;text-align:center;">' + formatAbandonmentNumber(ageCount2) + '</span>';
				}
				html += '</div></div>';
			}
		} else {
			// Specific age tab
			var selectedAge = data.byAge[currentAbandonmentTab];
			if (selectedAge) {
				var tabCount = includeAnonymous ? selectedAge.count : selectedAge.withCustomer;
				var tabValue = includeAnonymous ? selectedAge.value : selectedAge.valueWithEmail;

				html += '<div class="bs-kpi-grid bs-kpi-grid--3">';
				html += '<div class="bs-kpi-card"><div class="bs-kpi-card__header"><p class="bs-kpi-card__label">Abandoned Carts</p></div>';
				html += '<p class="bs-kpi-card__value">' + formatAbandonmentNumber(tabCount) + '</p></div>';

				html += '<div class="bs-kpi-card"><div class="bs-kpi-card__header"><p class="bs-kpi-card__label">Abandoned Value</p></div>';
				html += '<p class="bs-kpi-card__value">' + formatAbandonmentCurrency(tabValue || 0) + '</p></div>';

				html += '<div class="bs-kpi-card"><div class="bs-kpi-card__header"><p class="bs-kpi-card__label">Avg Cart Value</p></div>';
				html += '<p class="bs-kpi-card__value">' + formatAbandonmentCurrency(tabCount > 0 ? (tabValue || 0) / tabCount : 0) + '</p></div>';
				html += '</div>';
			}
		}

		abandonmentContainer.innerHTML = html;
	}

	// Tab switching
	document.querySelectorAll('[data-abandonment-tab]').forEach(function (tabButton) {
		tabButton.addEventListener('click', function () {
			currentAbandonmentTab = this.getAttribute('data-abandonment-tab');
			document.querySelectorAll('[data-abandonment-tab]').forEach(function (button) {
				button.classList.remove('bs-chart-toggle__btn--active');
			});
			this.classList.add('bs-chart-toggle__btn--active');
			renderAbandonment();
		});
	});

	// Anonymous toggle
	if (anonymousToggle) {
		anonymousToggle.addEventListener('change', renderAbandonment);
	}

	renderAbandonment();

	// Items per order chart (with clickable bars)
	{% if itemsPerOrder.counts|length > 0 %}
	var ipoLabels = {{ itemsPerOrder.labels|json_encode|raw }};
	var ipoChart = new Chart(document.getElementById('itemsPerOrderChart').getContext('2d'), {
		type: 'bar',
		data: {
			labels: ipoLabels,
			datasets: [{
				label: '{{ "Orders"|t("best-sellers") }}',
				data: {{ itemsPerOrder.counts|json_encode|raw }},
				backgroundColor: 'rgba(0, 115, 170, 0.6)',
				borderColor: '#0073aa',
				borderWidth: 1
			}]
		},
		options: {
			responsive: true,
			maintainAspectRatio: false,
			plugins: { legend: { display: false } },
			scales: {
				x: { title: { display: true, text: '{{ "Items"|t("best-sellers") }}' } },
				y: { beginAtZero: true, title: { display: true, text: '{{ "Orders"|t("best-sellers") }}' } }
			},
			onClick: function (evt) {
				var points = ipoChart.getElementsAtEventForMode(evt, 'nearest', { intersect: true }, false);
				if (points.length > 0) {
					var bucket = ipoLabels[points[0].index];
					window.location.href = '{{ cpUrl("best-sellers/orders") }}' + '?itemsPerOrder=' + encodeURIComponent(bucket);
				}
			},
			onHover: function (evt, elements) {
				evt.native.target.style.cursor = elements.length > 0 ? 'pointer' : 'default';
			}
		}
	});
	{% endif %}

});
{% endjs %}
