{% extends 'best-sellers/_layouts/reports' %}
{% do view.registerTranslations('best-sellers', [
	'Filtered: {label}',
	'Clear filter',
	'Shipping: {method}',
	'Discounted orders',
	'Full-price orders',
	'Discount ID: {id}',
	'Items per order: {bucket}',
]) %}

{% set title = "Orders"|t('best-sellers') %}
{% set selectedSubnavItem = 'orders' %}

{% block reportContent %}
	{# Written Summary #}
	<div class="bs-chart-container" style="margin-bottom: 2rem;">
		<p style="font-size: 1.1rem; margin: 0;">
			{{ "Revenue is"|t('best-sellers') }}
			{% if revenueChange is not null %}
				{% if revenueChange >= 0 %}
					<strong style="color: #27ae60;">{{ "up"|t('best-sellers') }} {{ revenueChange|abs|number_format(2) }}%</strong>
				{% else %}
					<strong style="color: #e74c3c;">{{ "down"|t('best-sellers') }} {{ revenueChange|abs|number_format(2) }}%</strong>
				{% endif %}
			{% else %}
				<strong>---</strong>
			{% endif %}
			{{ "for the selected date range compared to the previous period."|t('best-sellers') }}
			{{ "You also have"|t('best-sellers') }}
			<strong{% if ordersChange is not null and ordersChange < 0 %} style="color: #e74c3c;"{% elseif ordersChange is not null and ordersChange >= 0 %} style="color: #27ae60;"{% endif %}>{{ stats.totalOrders|number_format }} {{ "orders"|t('best-sellers') }}{% if ordersChange is not null %} ({{ ordersChange >= 0 ? 'up'|t('best-sellers') : 'down'|t('best-sellers') }} {{ "by"|t('best-sellers') }} {{ ordersChange|abs|number_format(2) }}%){% endif %}</strong>.
		</p>
	</div>

	{# Filters #}
	{% set orderStatuses = craft.commerce.orderStatuses.allOrderStatuses %}
	<div class="bs-section">
		<div class="bs-filter-bar" style="margin-bottom: 1rem;">
			<div class="bs-multiselect" id="order-status-multiselect">
				<button type="button" class="bs-multiselect__btn" data-label="{{ 'Order Status'|t('best-sellers') }}">{{ "Order Status"|t('best-sellers') }}</button>
				<div class="bs-multiselect__dropdown">
					{% for status in orderStatuses %}
						<label><input type="checkbox" value="{{ status.handle }}"> {{ status.name }}</label>
					{% endfor %}
				</div>
			</div>
			<div class="bs-multiselect" id="payment-status-multiselect">
				<button type="button" class="bs-multiselect__btn" data-label="{{ 'Payment Status'|t('best-sellers') }}">{{ "Payment Status"|t('best-sellers') }}</button>
				<div class="bs-multiselect__dropdown">
					<label><input type="checkbox" value="paid"> {{ "Paid"|t('best-sellers') }}</label>
					<label><input type="checkbox" value="partial"> {{ "Partial"|t('best-sellers') }}</label>
					<label><input type="checkbox" value="unpaid"> {{ "Unpaid"|t('best-sellers') }}</label>
				</div>
			</div>
			{% if shippingMethods is defined and shippingMethods|length > 0 %}
				<div class="bs-multiselect" id="shipping-method-multiselect">
					<button type="button" class="bs-multiselect__btn" data-label="{{ 'Shipping'|t('best-sellers') }}">{{ "Shipping"|t('best-sellers') }}</button>
					<div class="bs-multiselect__dropdown">
						{% for method in shippingMethods %}
							<label><input type="checkbox" value="{{ method.method }}"> {{ method.method }}</label>
						{% endfor %}
					</div>
				</div>
			{% endif %}
			<div class="bs-multiselect" id="discount-status-multiselect">
				<button type="button" class="bs-multiselect__btn" data-label="{{ 'Discount'|t('best-sellers') }}">{{ "Discount"|t('best-sellers') }}</button>
				<div class="bs-multiselect__dropdown">
					<label><input type="checkbox" value="discounted"> {{ "Discounted"|t('best-sellers') }}</label>
					<label><input type="checkbox" value="fullPrice"> {{ "Full Price"|t('best-sellers') }}</label>
					{% if topDiscounts is defined and topDiscounts|length > 0 %}
						<hr style="margin: 0.3rem 1rem; border: none; border-top: 1px solid #e0e0e0;">
						{% for discount in topDiscounts %}
							{% if discount.discountId %}
								<label><input type="checkbox" value="discount:{{ discount.discountId }}"> {{ discount.name }}</label>
							{% endif %}
						{% endfor %}
					{% endif %}
				</div>
			</div>
			<div class="bs-filter-bar__item">
				<input type="text" id="orders-search" class="text fullwidth" placeholder="{{ 'Search orders...'|t('best-sellers') }}" autocomplete="off">
			</div>
		</div>

		{# Loading State #}
		<div id="orders-loading" class="bs-loading">
			<div class="bs-loading__spinner"></div>
			<p class="bs-loading__message">{{ "Rummaging through the order archives..."|t('best-sellers') }}</p>
		</div>

		{# Orders Table (hidden until loaded) #}
		<div id="orders-container" style="display: none;">
			<div style="overflow-x: auto;">
				<table class="bs-data-table" id="orders-table">
					<thead>
						<tr>
							<th data-sort="reference">{{ "Order #"|t('best-sellers') }}</th>
							<th data-sort="dateOrdered">{{ "Date Ordered"|t('best-sellers') }}</th>
							<th data-sort="orderStatusId">{{ "Status"|t('best-sellers') }}</th>
							<th class="bs-data-table--right" data-sort="itemSubtotal">{{ "Merchandise Total"|t('best-sellers') }}</th>
							<th class="bs-data-table--right" data-sort="totalTax">{{ "Tax"|t('best-sellers') }}</th>
							<th class="bs-data-table--right" data-sort="totalDiscount">{{ "Discount"|t('best-sellers') }}</th>
							<th class="bs-data-table--right" data-sort="totalShippingCost">{{ "Shipping"|t('best-sellers') }}</th>
							<th class="bs-data-table--right" data-sort="totalPaid">{{ "Total Paid"|t('best-sellers') }}</th>
							<th class="bs-data-table--right">{{ "Items Sold"|t('best-sellers') }}</th>
							<th data-sort="paidStatus">{{ "Payment"|t('best-sellers') }}</th>
						</tr>
					</thead>
					<tbody id="orders-tbody"></tbody>
				</table>
			</div>

			<div id="orders-pagination" style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem;"></div>
		</div>
	</div>
{% endblock %}

{% js %}
document.addEventListener('DOMContentLoaded', function () {
	var searchInput = document.getElementById('orders-search');
	var searchTimer = null;

	var orderStatusMulti = BestSellersReports.createMultiSelect({
		container: document.getElementById('order-status-multiselect'),
		onChange: function () { table.reload(); }
	});

	var paymentStatusMulti = BestSellersReports.createMultiSelect({
		container: document.getElementById('payment-status-multiselect'),
		onChange: function () { table.reload(); }
	});

	var shippingMethodMulti = BestSellersReports.createMultiSelect({
		container: document.getElementById('shipping-method-multiselect'),
		onChange: function () { table.reload(); }
	});

	var discountStatusMulti = BestSellersReports.createMultiSelect({
		container: document.getElementById('discount-status-multiselect'),
		onChange: function () { table.reload(); }
	});

	var table = BestSellersReports.createAjaxTable({
		loadingEl: document.getElementById('orders-loading'),
		containerEl: document.getElementById('orders-container'),
		tbodyEl: document.getElementById('orders-tbody'),
		paginationEl: document.getElementById('orders-pagination'),
		actionUrl: 'best-sellers/orders/orders-data',
		exportUrl: 'best-sellers/orders/export-csv',
		baseParams: { from: '{{ from }}', to: '{{ to }}', preset: '{{ preset }}' },
		defaultSort: 'dateOrdered',
		defaultSortDir: 'desc',
		itemLabel: 'orders',
		emptyMessage: 'No orders found matching your filters.',
		buildRow: function (order) {
			var row = document.createElement('tr');
			row.innerHTML =
				'<td><a href="' + order.cpEditUrl + '" class="go">' + order.reference + '</a></td>' +
				'<td>' + order.dateOrdered + '</td>' +
				'<td><span class="status ' + order.statusColor + '"></span> ' + order.statusName + '</td>' +
				'<td class="bs-data-table--right">' + order.itemSubtotal + '</td>' +
				'<td class="bs-data-table--right">' + order.totalTax + '</td>' +
				'<td class="bs-data-table--right">' + order.totalDiscount + '</td>' +
				'<td class="bs-data-table--right">' + order.totalShippingCost + '</td>' +
				'<td class="bs-data-table--right">' + order.totalPaid + '</td>' +
				'<td class="bs-data-table--right">' + order.itemsSold + '</td>' +
				'<td>' + order.paidStatusHtml + '</td>';
			return row;
		},
		buildTotalsRow: function (totals) {
			var row = document.createElement('tr');
			row.innerHTML =
				'<td>{{ "All Results Total"|t("best-sellers") }}</td>' +
				'<td></td>' +
				'<td></td>' +
				'<td class="bs-data-table--right">' + totals.itemSubtotal + '</td>' +
				'<td class="bs-data-table--right">' + totals.totalTax + '</td>' +
				'<td class="bs-data-table--right">' + totals.totalDiscount + '</td>' +
				'<td class="bs-data-table--right">' + totals.totalShippingCost + '</td>' +
				'<td class="bs-data-table--right">' + totals.totalPaid + '</td>' +
				'<td class="bs-data-table--right">' + totals.itemsSold + '</td>' +
				'<td></td>';
			return row;
		},
		getFilterParams: function () {
			var params = {};
			var searchValue = searchInput ? searchInput.value.trim() : '';
			if (searchValue) { params.search = searchValue; }
			var orderStatuses = orderStatusMulti.getSelected();
			if (orderStatuses.length > 0) { params['orderStatus[]'] = orderStatuses; }
			var paymentStatuses = paymentStatusMulti.getSelected();
			if (paymentStatuses.length > 0) { params['paymentStatus[]'] = paymentStatuses; }
			if (shippingMethodMulti) {
				var shippingMethods = shippingMethodMulti.getSelected();
				if (shippingMethods.length > 0) { params['shippingMethod'] = shippingMethods[0]; }
			}
			if (discountStatusMulti) {
				var discountSelections = discountStatusMulti.getSelected();
				discountSelections.forEach(function (val) {
					if (val.indexOf('discount:') === 0) {
						params['discountId'] = val.substring(9);
					} else {
						params['discountStatus'] = val;
					}
				});
			}
			return params;
		},
		restoreFilterState: function (filters) {
			if (filters.search && searchInput) {
				searchInput.value = filters.search;
			}
			if (filters['orderStatus[]']) {
				var orderStatusContainer = document.getElementById('order-status-multiselect');
				var orderStatusCheckboxes = orderStatusContainer.querySelectorAll('input[type="checkbox"]');
				var orderStatusValues = filters['orderStatus[]'];
				orderStatusCheckboxes.forEach(function (checkbox) {
					checkbox.checked = orderStatusValues.indexOf(checkbox.value) !== -1;
				});
				orderStatusMulti.refresh();
			}
			if (filters['paymentStatus[]']) {
				var paymentStatusContainer = document.getElementById('payment-status-multiselect');
				var paymentStatusCheckboxes = paymentStatusContainer.querySelectorAll('input[type="checkbox"]');
				var paymentStatusValues = filters['paymentStatus[]'];
				paymentStatusCheckboxes.forEach(function (checkbox) {
					checkbox.checked = paymentStatusValues.indexOf(checkbox.value) !== -1;
				});
				paymentStatusMulti.refresh();
			}
			if (filters.shippingMethod && shippingMethodMulti) {
				var shippingContainer = document.getElementById('shipping-method-multiselect');
				if (shippingContainer) {
					shippingContainer.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
						cb.checked = cb.value === filters.shippingMethod;
					});
					shippingMethodMulti.refresh();
				}
			}
			if ((filters.discountStatus || filters.discountId) && discountStatusMulti) {
				var discountContainer = document.getElementById('discount-status-multiselect');
				if (discountContainer) {
					discountContainer.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
						if (filters.discountStatus && cb.value === filters.discountStatus) {
							cb.checked = true;
						} else if (filters.discountId && cb.value === 'discount:' + filters.discountId) {
							cb.checked = true;
						}
					});
					discountStatusMulti.refresh();
				}
			}
		}
	});

	if (searchInput) {
		searchInput.addEventListener('input', function () {
			clearTimeout(searchTimer);
			searchTimer = setTimeout(function () { table.reload(); }, 400);
		});
	}

	table.init();

	// Pre-check dropdowns from URL params (for cross-page filter links)
	try {
		var urlParams = new URLSearchParams(window.location.search);
		var urlShipping = urlParams.get('shippingMethod');
		var urlDiscountStatus = urlParams.get('discountStatus');
		var urlDiscountId = urlParams.get('discountId');

		if (urlShipping && shippingMethodMulti) {
			var shipContainer = document.getElementById('shipping-method-multiselect');
			if (shipContainer) {
				shipContainer.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
					cb.checked = cb.value === urlShipping;
				});
				shippingMethodMulti.refresh();
			}
		}
		if ((urlDiscountStatus || urlDiscountId) && discountStatusMulti) {
			var discContainer = document.getElementById('discount-status-multiselect');
			if (discContainer) {
				discContainer.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
					if (urlDiscountStatus && cb.value === urlDiscountStatus) {
						cb.checked = true;
					} else if (urlDiscountId && cb.value === 'discount:' + urlDiscountId) {
						cb.checked = true;
					}
				});
				discountStatusMulti.refresh();
			}
		}
	} catch (e) {
		// URLSearchParams not supported
	}
});
{% endjs %}
